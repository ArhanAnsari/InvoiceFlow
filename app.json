{
  "expo": {
    "name": "InvoiceFlow",
    "slug": "InvoiceFlow",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/app-assets/ios/icons/ios-icon-1024.png",
    "scheme": "invoiceflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/app-assets/ios/icons/ios-icon-1024.png",
      "bundleIdentifier": "com.arhanansari.InvoiceFlow",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/images/app-assets/android/icons/android-icon-512.png",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/app-assets/android/icons/android-icon-512.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.arhanansari.InvoiceFlow"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-assets/android/icons/android-icon-96.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-assets/ios/splash/ios-splash-2732x2732.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/app-assets/ios/splash/ios-splash-2732x2732.png",
            "backgroundColor": "#0D0F1E"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "invoiceflow",
          "organization": "arhanansari"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee769015-84d0-4c34-848d-69fb685533b2"
      }
    },
    "owner": "arhanansari",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ee769015-84d0-4c34-848d-69fb685533b2"
    }
  }
}
